# Copy to .env (gitignored) and fill in. Used by the digikey skill for part
# search, pricing/stock checks, and datasheet downloads.
# Get credentials: https://developer.digikey.com (create an app, Product Information API)
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Optional — used by the part-models skill. With a key set, SnapEDA/SnapMagic model
# search+download becomes agent-automatable (Tier A) instead of hand-off (Tier B).
# Free tier; request access: https://www.snapeda.com/get-api/
SNAPEDA_API_KEY=
